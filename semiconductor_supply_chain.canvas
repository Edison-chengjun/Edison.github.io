    {
      "id": "interposer-header",
      "type": "text",
      "x": 1020,
      "y": 140,
      "width": 300,
      "height": 60,
      "text": "## 五、存储墙 / CMC 合封\nInterposer & High-end Substrate\n\n2.5D/3D 堆叠需求激增"
    },
    {
      "id": "interposer-si",
      "type": "text",
      "x": 1020,
      "y": 220,
      "width": 260,
      "height": 80,
      "text": "**Silicon Interposer**\n台积电 CoWoS（自产）\n英特尔 EMIB"
    },
    {
      "id": "interposer-glass",
      "type": "text",
      "x": 1020,
      "y": 320,
